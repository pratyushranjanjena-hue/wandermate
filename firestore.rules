rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /trips/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /events/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /posts/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /history/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
